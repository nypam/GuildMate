package-as: GuildMate

# ── Note on library management ─────────────────────────────────────────────
# Normally the packager should fetch Ace3 / LibStub / LibDataBroker / LibDBIcon
# from CurseForge's SVN at build time via an `externals:` block. That's the
# canonical approach and what most addons do — it keeps libraries
# auto-updated to upstream trunk.
#
# However, repos.curseforge.com is intermittently unreliable (frequent 503s
# on release builds), which blocks CI and stops us from shipping. For now
# we vendor the libraries directly under Libs/ and let the packager bundle
# whatever is there. This means:
#
#   ✓ Builds don't depend on CurseForge SVN availability
#   ✗ Lib updates require a manual refresh of the Libs/ folder
#
# When CurseForge stabilizes (or if we move to GitHub-hosted lib mirrors),
# restore the `externals:` block so libs auto-update again.
# ───────────────────────────────────────────────────────────────────────────

ignore:
  - .github
  - .gitignore
  - .pkgmeta
  - CLAUDE.md
  - docs
  - Updates.md
